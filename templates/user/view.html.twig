{% extends 'base.html.twig' %}

{% block title %}{{ profile.displayName }} — Trepiedi{% endblock %}

{% block body %}
    <a class="btn btn-link px-0 mb-2" href="{{ path('app_leaderboard') }}">← {{ 'nav.leaderboard'|trans }}</a>

    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                {% if profile.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ profile.avatar) }}" alt="" class="avatar-lg">
                {% else %}
                    <span class="avatar-lg avatar-empty">{{ profile.displayName|first|upper }}</span>
                {% endif %}
                <div>
                <h1 class="h4 mb-1">{{ profile.displayName }}{% if isSelf %} <span class="badge text-bg-success">{{ 'prof.you'|trans }}</span>{% endif %}</h1>
                {% if entry %}
                    <span class="text-muted">{{ 'prof.stats'|trans({'%rank%': entry.rank, '%home%': entry.homeCorrect, '%away%': entry.awayCorrect, '%exact%': entry.exactCount, '%winner%': entry.advanceCount}) }}</span>
                {% else %}
                    <span class="text-muted">{{ 'prof.no_points'|trans }}</span>
                {% endif %}
                </div>
            </div>
            {% if entry %}
                <div class="text-end">
                    <div class="h3 mb-0">{{ entry.weightedTotal|number_format(1, ',', '.') }}</div>
                    <small class="text-muted">{{ 'prof.points_raw'|trans({'%raw%': entry.rawTotal}) }}</small>
                </div>
            {% endif %}
        </div>
    </div>

    {% for group in rounds %}
        <section class="mb-4">
            <h2 class="h6 text-success border-bottom pb-2">
                {{ group.round.name }} <span class="text-muted fw-normal">(× {{ group.round.weight }})</span>
            </h2>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 table-fixed">
                    <colgroup>
                        <col class="col-eq-5">
                        <col class="col-eq-5">
                        <col class="col-eq-5">
                        <col class="col-eq-5">
                        <col class="col-eq-5">
                    </colgroup>
                    <thead class="table-light">
                        <tr>
                            <th>{{ 'prof.match'|trans }}</th>
                            <th class="text-center">{{ 'prof.prediction'|trans }}</th>
                            <th class="text-center">{{ 'prof.winner'|trans }}</th>
                            <th>{{ 'prof.result'|trans }}</th>
                            <th class="text-center">{{ 'prof.points'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in group.items %}
                            {% set match = item.match %}
                            <tr>
                                <td>
                                    <a href="{{ path('app_match_view', {id: match.id}) }}">{{ match.homeTeam }} – {{ match.awayTeam }}</a>
                                    <div class="text-muted small">{{ match.kickoffAt|date('d-m H:i') }}</div>
                                </td>
                                {% if not item.visible %}
                                    <td class="text-center text-muted small">{{ 'prof.hidden'|trans }}</td>
                                    <td class="text-center text-muted small">🔒</td>
                                {% elseif item.prediction %}
                                    <td class="text-center"><strong>{{ item.prediction.homeScore }} – {{ item.prediction.awayScore }}</strong></td>
                                    <td class="text-center">{{ item.prediction.advancingTeam ?? '—' }}</td>
                                {% else %}
                                    <td class="text-center text-muted">{{ 'prof.no_prediction'|trans }}</td>
                                    <td class="text-center text-muted">{{ 'prof.no_prediction'|trans }}</td>
                                {% endif %}
                                <td>
                                    {% if match.finished %}
                                        {{ match.homeScore }} – {{ match.awayScore }}
                                        <span class="text-muted small">· {{ match.advancingTeam }}</span>
                                    {% else %}<span class="text-muted small">{{ 'prof.no_result'|trans }}</span>{% endif %}
                                </td>
                                <td class="text-center">
                                    {% if item.score %}
                                        <span class="badge text-bg-success">+{{ item.score.total * match.round.weight }}</span>
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% else %}
        <div class="alert alert-info">{{ 'prof.no_matches'|trans }}</div>
    {% endfor %}
{% endblock %}
