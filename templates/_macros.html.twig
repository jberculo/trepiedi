{# Profielfoto (of initiaal) van een gebruiker. #}
{% macro avatar(user, size) %}
    {%- set s = size|default('sm') -%}
    {%- if user.avatar -%}
        <img src="{{ asset('uploads/avatars/' ~ user.avatar ~ '-' ~ s ~ '.jpg') }}" alt="" class="avatar-{{ s }}">
    {%- else -%}
        <span class="avatar-{{ s }} avatar-empty">{{ user.displayName|first|upper }}</span>
    {%- endif -%}
{% endmacro %}

{# Klikbare spelernaam met fotootje ervoor. #}
{% macro player(user) %}
    <a class="d-inline-flex align-items-center gap-2 text-decoration-none" href="{{ path('app_user_view', {slug: user.slug}) }}">
        {{ _self.avatar(user, 'sm') }}<span>{{ user.displayName }}</span>
    </a>
{% endmacro %}

{# Ploeg: vlag + naam. Met flag_first=false komt de vlag achter de naam. #}
{% macro team(name, flag_first) %}
    {%- if flag_first is same as(false) -%}
        {{ name }} {{ country_flag(name) }}
    {%- else -%}
        {{ country_flag(name) }}{{ name }}
    {%- endif -%}
{% endmacro %}

{# Doorgaande ploeg (vlag + naam), of een streepje als die er (nog) niet is. #}
{% macro team_or_dash(name) %}{% if name %}{{ _self.team(name) }}{% else %}&mdash;{% endif %}{% endmacro %}

{# Score-badge: +punten (de aanroeper rekent het rondegewicht al mee). #}
{% macro points_badge(points) %}<span class="badge text-bg-success">+{{ points }}</span>{% endmacro %}

{# POST-knop met CSRF-token (en optioneel een bevestiging). variant = bootstrap-outline-kleur. #}
{% macro csrf_button(action, token, label, variant, confirm) %}
    <form method="post" action="{{ action }}" class="d-inline"{% if confirm %} onsubmit="return confirm('{{ confirm }}');"{% endif %}>
        <input type="hidden" name="_token" value="{{ token }}">
        <button class="btn btn-sm btn-outline-{{ variant|default('danger') }}">{{ label }}</button>
    </form>
{% endmacro %}
