{% extends 'base.html.twig' %}

{% block title %}{{ 'account.title'|trans }} — Trepiedi{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="h4 mb-3">{{ 'account.heading'|trans }}</h1>
            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.displayName, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.displayName, {attr: {class: 'form-control'}}) }}
                            {{ form_errors(form.displayName) }}
                        </div>

                        <div class="mb-3">
                            <span class="form-label d-block">{{ 'account.current_photo'|trans }}</span>
                            {% if app.user.avatar %}
                                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="" class="avatar-lg">
                            {% else %}
                                <span class="avatar-lg avatar-empty">{{ app.user.displayName|first|upper }}</span>
                            {% endif %}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.avatar, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.avatar, {attr: {class: 'form-control'}}) }}
                            {{ form_errors(form.avatar) }}
                        </div>

                        <button class="btn btn-success">{{ 'common.save'|trans }}</button>
                    {{ form_end(form) }}

                    <hr class="my-4">

                    <span class="form-label d-block">{{ 'account.language'|trans }}</span>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm d-flex align-items-center {{ app.request.locale == 'nl' ? 'btn-success' : 'btn-outline-secondary' }}" href="{{ path('app_locale', {_locale: 'nl'}) }}">
                            <span class="fi fi-nl team-flag"></span>Nederlands
                        </a>
                        <a class="btn btn-sm d-flex align-items-center {{ app.request.locale == 'en' ? 'btn-success' : 'btn-outline-secondary' }}" href="{{ path('app_locale', {_locale: 'en'}) }}">
                            <span class="fi fi-gb team-flag"></span>English
                        </a>
                    </div>

                    {% set my_pools = app.user.pools|filter(p => not p.archived) %}
                    {% if my_pools|length > 1 %}
                        {% set current_pool = active_pool() %}
                        <hr class="my-4">
                        <span class="form-label d-block">{{ 'account.pool'|trans }}</span>
                        <div class="d-flex flex-wrap gap-2">
                            {% for p in my_pools %}
                                <a class="btn btn-sm {{ current_pool and p.id == current_pool.id ? 'btn-success' : 'btn-outline-secondary' }}" href="{{ path('app_pool_switch', {code: p.code}) }}">
                                    {{ p.name }}{% if p.default %} <span class="small">({{ 'admin.pool_is_default'|trans }})</span>{% endif %}
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
