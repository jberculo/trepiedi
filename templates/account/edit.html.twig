{% extends 'base.html.twig' %}

{% import '_macros.html.twig' as m %}

{% block title %}{{ 'account.title'|trans }} - Trepiedi{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="h4 mb-3">{{ 'account.heading'|trans }}</h1>
            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.displayName, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.displayName, {attr: {class: 'form-control'}}) }}
                            {{ form_errors(form.displayName) }}
                        </div>

                        <div class="mb-3">
                            <span class="form-label d-block">{{ 'account.current_photo'|trans }}</span>
                            {{ m.avatar(app.user, 'lg') }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.avatar, null, {label_attr: {class: 'form-label'}}) }}
                            {{ form_widget(form.avatar, {attr: {class: 'form-control'}}) }}
                            {{ form_errors(form.avatar) }}
                        </div>

                        <button class="btn btn-success">{{ 'common.save'|trans }}</button>
                    {{ form_end(form) }}

                    <hr class="my-4">

                    <span class="form-label d-block">{{ 'account.language'|trans }}</span>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm d-flex align-items-center {{ app.request.locale == 'nl' ? 'btn-success' : 'btn-outline-secondary' }}" href="{{ path('app_locale', {_locale: 'nl'}) }}">
                            <span class="fi fi-nl team-flag"></span>{{ 'account.language_nl'|trans }}
                        </a>
                        <a class="btn btn-sm d-flex align-items-center {{ app.request.locale == 'en' ? 'btn-success' : 'btn-outline-secondary' }}" href="{{ path('app_locale', {_locale: 'en'}) }}">
                            <span class="fi fi-gb team-flag"></span>{{ 'account.language_en'|trans }}
                        </a>
                    </div>

                    {% set my_pools = switchable_pools() %}
                    {% if my_pools|length > 1 %}
                        <hr class="my-4">
                        {{ include('pool/_switcher.html.twig', {
                            pools: my_pools,
                            current_pool: active_pool(),
                            switcher_variant: 'buttons'
                        }) }}
                    {% endif %}

                    <hr class="my-4">
                    <span class="form-label d-block">{{ 'account.api_token'|trans }}</span>
                    <p class="text-muted small mb-2">{{ 'account.api_token_help'|trans }}</p>
                    {% if plainApiToken %}
                        <div class="alert alert-warning small" role="alert">{{ 'account.api_token_once'|trans }}</div>
                        <div class="input-group input-group-sm mb-2">
                            <input type="text" class="form-control font-monospace" value="{{ plainApiToken }}" readonly onclick="this.select()">
                        </div>
                    {% elseif app.user.hasApiToken %}
                        <p class="small text-muted mb-2">{{ 'account.api_token_exists'|trans({'%id%': app.user.apiTokenId}) }}</p>
                    {% else %}
                        <p class="small text-muted mb-2">{{ 'account.api_token_missing'|trans }}</p>
                    {% endif %}
                    <form method="post" action="{{ path('app_account_api_token') }}"
                          onsubmit="return confirm('{{ 'account.api_token_confirm'|trans }}');">
                        <input type="hidden" name="_token" value="{{ csrf_token('api-token-' ~ app.user.id) }}">
                        <button class="btn btn-sm btn-outline-secondary">{{ 'account.api_token_generate'|trans }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
