{% import '_macros.html.twig' as m %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('nl') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Trepiedi - Voetbalpoule{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/trepiedi-icon.svg') }}">
        <link href="{{ asset('vendor/bootstrap/bootstrap.min.css') }}?v={{ asset_version('vendor/bootstrap/bootstrap.min.css') }}" rel="stylesheet">
        <link href="{{ asset('css/base.css') }}?v={{ asset_version('css/base.css') }}" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_leaderboard') }}">
                    <img src="{{ asset('images/trepiedi-logo-white.svg') }}" alt="Trepiedi">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav"
                        aria-controls="nav" aria-expanded="false" aria-label="{{ 'nav.toggle'|trans }}">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="nav">
                    <ul class="navbar-nav me-auto align-items-end align-items-lg-start">
                        {% if app.user %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_dashboard') }}">{{ 'nav.predict'|trans }}</a></li>
                        {% endif %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_leaderboard') }}">{{ 'nav.leaderboard'|trans }}</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_matches') }}">{{ 'nav.matches'|trans }}</a></li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">{{ 'nav.admin'|trans }}</a></li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav align-items-end align-items-lg-center mt-2 mt-lg-0">
                        {% if not app.user %}
                            {# Ingelogde gebruikers wisselen taal via hun profiel; uitgelogde bezoekers hier. #}
                            <li class="nav-item">
                                <span class="navbar-text small me-2">
                                    <a class="link-light text-decoration-none {{ app.request.locale == 'nl' ? 'fw-bold' }}" href="{{ path('app_locale', {_locale: 'nl'}) }}">NL</a>
                                    <span class="text-white-50"> | </span>
                                    <a class="link-light text-decoration-none {{ app.request.locale == 'en' ? 'fw-bold' }}" href="{{ path('app_locale', {_locale: 'en'}) }}">EN</a>
                                </span>
                            </li>
                        {% endif %}
                        {% if app.user %}
                            {% set navbar_pools = switchable_pools() %}
                        {% endif %}
                        {% if app.user and navbar_pools|length > 1 %}
                            {{ include('pool/_switcher.html.twig', {
                                pools: navbar_pools,
                                current_pool: active_pool(),
                                switcher_variant: 'dropdown'
                            }) }}
                        {% endif %}
                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2" href="{{ path('app_account') }}">
                                    {% if app.user.avatar %}{{ m.avatar(app.user, 'sm') }}{% endif %}
                                    {{ app.user.displayName }}
                                </a>
                            </li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}">{{ 'auth.logout'|trans }}</a></li>
                        {% else %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">{{ 'auth.login'|trans }}</a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">{{ 'auth.register'|trans }}</a></li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <main class="container pb-5">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message|trans }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% if app.user and pool_orphan() %}
                <div class="alert alert-warning" role="alert">{{ 'pool.orphan_notice'|trans }}</div>
            {% endif %}

            {% if app.user and app.user.hasNotice %}
                {# Start verborgen; app.js toont 'm alleen als hij niet is weggeklikt (voorkomt een flits). #}
                <div class="alert alert-{{ app.user.noticeType.bootstrapClass }} alert-dismissible fade show d-none" role="alert"
                     data-dismiss-store="trepiedi:notice-dismissed" data-dismiss-token="{{ app.user.noticeSignature }}-{{ 'now'|date('Y-m-d') }}">
                    {{ app.user.notice|nl2br }}
                    <button type="button" class="btn-close" data-dismiss-close aria-label="{{ 'common.close'|trans }}"></button>
                </div>
            {% endif %}

            {% if app.user %}
                {% set open_unpredicted = open_unpredicted_count() %}
                {% if open_unpredicted > 0 %}
                    <div class="alert alert-info alert-dismissible fade show d-none" role="alert"
                         data-dismiss-store="trepiedi:predict-reminder-dismissed" data-dismiss-token="{{ 'now'|date('Y-m-d') }}">
                        {{ 'dash.predict_reminder'|trans({'%count%': open_unpredicted}) }}
                        <a href="{{ path('app_dashboard') }}" class="alert-link">{{ 'dash.predict_reminder_link'|trans }}</a>
                        <button type="button" class="btn-close" data-dismiss-close aria-label="{{ 'common.close'|trans }}"></button>
                    </div>
                {% endif %}
            {% endif %}

            {% block body %}{% endblock %}
        </main>

        <footer class="site-footer mt-5 py-4">
            <div class="container text-center small">
                <div class="footer-brand fs-5">&#9917; Trepiedi</div>
                <div class="text-white-50">{{ 'footer.tagline'|trans }}</div>
            </div>
        </footer>

        <script src="{{ asset('vendor/bootstrap/bootstrap.bundle.min.js') }}?v={{ asset_version('vendor/bootstrap/bootstrap.bundle.min.js') }}"></script>
        <script src="{{ asset('js/app.js') }}?v={{ asset_version('js/app.js') }}" defer></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
