<!DOCTYPE html>
<html lang="{{ app.request.locale|default('nl') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Trepiedi — Voetbalpoule{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/trepiedi-icon.svg') }}">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" rel="stylesheet">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;700&family=Rubik:wght@400;500;700&display=swap" rel="stylesheet">
        <link href="{{ asset('css/app.css') }}?v={{ asset_version('css/app.css') }}" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_leaderboard') }}">
                    <img src="{{ asset('images/trepiedi-logo-white.svg') }}" alt="Trepiedi">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="nav">
                    <ul class="navbar-nav me-auto align-items-end align-items-lg-start">
                        {% if app.user %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_dashboard') }}">{{ 'nav.predict'|trans }}</a></li>
                        {% endif %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_leaderboard') }}">{{ 'nav.leaderboard'|trans }}</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_matches') }}">{{ 'nav.matches'|trans }}</a></li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">{{ 'nav.admin'|trans }}</a></li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav align-items-end align-items-lg-center mt-2 mt-lg-0">
                        <li class="nav-item">
                            <span class="navbar-text small me-2">
                                <a class="link-light text-decoration-none {{ app.request.locale == 'nl' ? 'fw-bold' }}" href="{{ path('app_locale', {_locale: 'nl'}) }}">NL</a>
                                <span class="text-white-50">·</span>
                                <a class="link-light text-decoration-none {{ app.request.locale == 'en' ? 'fw-bold' }}" href="{{ path('app_locale', {_locale: 'en'}) }}">EN</a>
                            </span>
                        </li>
                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2" href="{{ path('app_account') }}">
                                    {% if app.user.avatar %}<img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="" class="avatar-sm">{% endif %}
                                    {{ app.user.displayName }}
                                </a>
                            </li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}">{{ 'auth.logout'|trans }}</a></li>
                        {% else %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_login') }}">{{ 'auth.login'|trans }}</a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('app_register') }}">{{ 'auth.register'|trans }}</a></li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <main class="container pb-5">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message|trans }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="site-footer mt-5 py-4">
            <div class="container text-center small">
                <div class="footer-brand fs-5">⚽ Trepiedi</div>
                <div class="text-white-50">{{ 'footer.tagline'|trans }}</div>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
