{% extends 'base.html.twig' %}

{% import '_macros.html.twig' as m %}

{% block title %}{{ 'matches.title'|trans }} — Trepiedi{% endblock %}

{% block body %}
    <div class="lb-hero mb-3">
        <h1 class="h3 mb-0">⚽ {{ 'matches.title'|trans }}</h1>
    </div>

    {% for group in groups %}
        <section class="mb-4">
            <h2 class="h5 text-success border-bottom pb-2">
                {{ group.round.name }} <span class="text-muted fw-normal small">(× {{ group.round.weight }})</span>
            </h2>
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>{{ 'matches.date'|trans }}</th>
                                <th colspan="2" class="text-center">{{ 'matches.match'|trans }}</th>
                                <th class="text-end">{{ 'matches.result'|trans }}</th>
                                <th>{{ 'matches.advances'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for match in group.matches %}
                                <tr>
                                    <td class="text-nowrap small">{{ match.kickoffAt|date('d-m-Y H:i') }}</td>
                                    <td class="text-end">
                                        <a class="text-decoration-none" href="{{ path('app_match_view', {id: match.id}) }}">{{ m.team(match.homeTeam, false) }}</a>
                                    </td>
                                    <td>
                                        <a class="text-decoration-none" href="{{ path('app_match_view', {id: match.id}) }}">{{ m.team(match.awayTeam) }}</a>
                                    </td>
                                    <td class="text-end text-nowrap">
                                        {% if match.finished %}
                                            <strong>{{ match.homeScore }} – {{ match.awayScore }}</strong>
                                        {% else %}
                                            <span class="text-muted small">{{ 'matches.not_played'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-nowrap">
                                        {% if match.finished and match.advancingTeam %}
                                            {{ m.team(match.advancingTeam) }}
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    {% else %}
        <div class="alert alert-info">{{ 'matches.none'|trans }}</div>
    {% endfor %}
{% endblock %}
