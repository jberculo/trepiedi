{% extends 'base.html.twig' %}

{% import '_macros.html.twig' as m %}

{% block title %}{{ match.homeTeam }} – {{ match.awayTeam }} — Trepiedi{% endblock %}

{% block body %}
    <a class="btn btn-link px-0 mb-2" href="{{ path('app_dashboard') }}">{{ 'mv.back'|trans }}</a>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="h4 mb-1">{{ m.team(match.homeTeam) }} – {{ m.team(match.awayTeam) }}</h1>
                    <p class="text-muted mb-0">
                        {{ match.round.name }} (× {{ match.round.weight }})
                        · {{ 'mv.kickoff'|trans }} {{ match.kickoffAt|date('d-m-Y H:i') }}
                    </p>
                </div>
                {% if match.finished %}
                    <div class="text-end">
                        <div class="h4 mb-0">{{ match.homeScore }} – {{ match.awayScore }}</div>
                        <small class="text-muted">{{ 'mv.winner'|trans }}: {{ m.team(match.advancingTeam) }}</small>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% if predictionCount == 0 %}
        <div class="alert alert-secondary">{{ 'mv.no_predictions'|trans }}</div>
    {% elseif not locked %}
        <div class="alert alert-info">{{ 'mv.hidden'|trans({'%count%': predictionCount}) }}</div>
    {% else %}
        {# Consensus #}
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card shadow-sm h-100"><div class="card-body">
                    <h2 class="h6 text-muted">{{ 'mv.consensus_winner'|trans }}</h2>
                    {% set total = advanceHome + advanceAway %}
                    <div class="mb-2">
                        <div class="d-flex justify-content-between small">
                            <span>{{ m.team(match.homeTeam) }}</span><span>{{ advanceHome }}</span>
                        </div>
                        <div class="progress" role="progressbar">
                            <div class="progress-bar bg-success" style="width: {{ total ? (advanceHome / total * 100)|round : 0 }}%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between small">
                            <span>{{ m.team(match.awayTeam) }}</span><span>{{ advanceAway }}</span>
                        </div>
                        <div class="progress" role="progressbar">
                            <div class="progress-bar bg-secondary" style="width: {{ total ? (advanceAway / total * 100)|round : 0 }}%"></div>
                        </div>
                    </div>
                </div></div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm h-100"><div class="card-body">
                    <h2 class="h6 text-muted">{{ 'mv.common_scores'|trans }}</h2>
                    <ul class="list-unstyled mb-0">
                        {% for line, count in scoreCounts|slice(0, 4) %}
                            <li class="d-flex justify-content-between">
                                <span>{{ line }}</span>
                                <span class="text-muted">{{ count }}×</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div></div>
            </div>
        </div>

        {# Alle voorspellingen #}
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{ 'lb.player'|trans }}</th>
                            <th class="text-center">{{ 'prof.prediction'|trans }}</th>
                            <th class="text-center">{{ 'prof.winner'|trans }}</th>
                            {% if match.finished %}<th class="text-center">{{ 'prof.points'|trans }}</th>{% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in rows %}
                            {% set p = row.prediction %}
                            <tr {% if app.user and p.user.id == app.user.id %}class="table-success"{% endif %}>
                                <td>{{ m.player(p.user) }}</td>
                                <td class="text-center"><strong>{{ p.homeScore }} – {{ p.awayScore }}</strong></td>
                                <td class="text-center">{{ m.team_or_dash(p.advancingTeam) }}</td>
                                {% if match.finished %}
                                    <td class="text-center">
                                        {{ m.points_badge(row.score.total * match.round.weight) }}
                                    </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
{% endblock %}
