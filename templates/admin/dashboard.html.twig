{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.title'|trans }} &mdash; Trepiedi{% endblock %}

{% block body %}
    <h1 class="h3 mb-4">{{ 'admin.title'|trans }}</h1>

    <div class="row g-3 mb-4">
        <div class="col-4">
            <div class="card text-center shadow-sm"><div class="card-body">
                <div class="display-6">{{ roundCount }}</div><div class="text-muted">{{ 'admin.rounds'|trans }}</div>
            </div></div>
        </div>
        <div class="col-4">
            <div class="card text-center shadow-sm"><div class="card-body">
                <div class="display-6">{{ finishedCount }}/{{ matchCount }}</div><div class="text-muted">{{ 'admin.matches_finished'|trans }}</div>
            </div></div>
        </div>
        <div class="col-4">
            <div class="card text-center shadow-sm"><div class="card-body">
                <div class="display-6">{{ userCount }}</div><div class="text-muted">{{ 'admin.players'|trans }}</div>
            </div></div>
        </div>
    </div>

    <div class="list-group">
        <a class="list-group-item list-group-item-action" href="{{ path('admin_match_index') }}">{{ 'admin.manage_matches'|trans }}</a>
        <a class="list-group-item list-group-item-action" href="{{ path('admin_round_index') }}">{{ 'admin.manage_rounds'|trans }}</a>
        <a class="list-group-item list-group-item-action" href="{{ path('admin_pool_index') }}">{{ 'admin.manage_pools'|trans }}</a>
        <a class="list-group-item list-group-item-action" href="{{ path('admin_participant_index') }}">{{ 'admin.manage_participants'|trans }}</a>
    </div>
{% endblock %}
