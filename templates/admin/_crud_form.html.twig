{% extends 'base.html.twig' %}

{% import '_macros.html.twig' as m %}

{% block title %}{{ title|trans }} &mdash; Trepiedi{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h1 class="h4 mb-3">{{ title|trans }}</h1>
            <div class="card shadow-sm"><div class="card-body">
                {{ form_start(form) }}
                    {% if avatar_preview is defined and avatar_preview %}
                        {# Huidige foto en het uploadveld bij elkaar. form_row markeert het
                           avatar-veld als gerenderd, zodat form_widget het niet nog eens toont. #}
                        <div class="mb-3 d-flex align-items-center gap-3">
                            {{ m.avatar(avatar_preview, 'lg') }}
                            <div class="flex-grow-1">{{ form_row(form.avatar) }}</div>
                        </div>
                    {% endif %}
                    {{ form_widget(form) }}
                    <div class="mt-3">
                        <button class="btn btn-success">{{ 'common.save'|trans }}</button>
                        <a class="btn btn-link" href="{{ back_path }}">{{ 'common.cancel'|trans }}</a>
                    </div>
                {{ form_end(form) }}
            </div></div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {% if avatar_preview is defined and avatar_preview %}
        <link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" rel="stylesheet">
    {% endif %}
{% endblock %}

{% block javascripts %}
    {% if include_country_autocomplete|default(false) %}
        <script src="{{ asset('js/country-autocomplete.js') }}?v={{ asset_version('js/country-autocomplete.js') }}" defer></script>
    {% endif %}
    {% if avatar_preview is defined and avatar_preview %}
        <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
        <script src="{{ asset('js/avatar-crop.js') }}?v={{ asset_version('js/avatar-crop.js') }}" defer></script>
    {% endif %}
{% endblock %}
