{% extends 'base.html.twig' %}

{% block title %}{{ title|trans }} — Trepiedi{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h1 class="h4 mb-3">{{ title|trans }}</h1>
            <div class="card shadow-sm"><div class="card-body">
                {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <div class="mt-3">
                        <button class="btn btn-success">{{ 'common.save'|trans }}</button>
                        <a class="btn btn-link" href="{{ back_path }}">{{ 'common.cancel'|trans }}</a>
                    </div>
                {{ form_end(form) }}
            </div></div>
        </div>
    </div>
{% endblock %}
