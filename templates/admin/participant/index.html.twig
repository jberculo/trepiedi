{% extends 'base.html.twig' %}

{% import '_macros.html.twig' as m %}

{% block title %}{{ 'admin.participants'|trans }} &mdash; {{ 'admin.title'|trans }}{% endblock %}

{% block body %}
    <h1 class="h3 mb-3">{{ 'admin.participants'|trans }}</h1>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'lb.player'|trans }}</th>
                        <th>{{ 'auth.email'|trans }}</th>
                        <th>{{ 'admin.pools'|trans }}</th>
                        <th>{{ 'admin.role'|trans }}</th>
                        <th class="text-end">{{ 'admin.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td><span class="d-inline-flex align-items-center gap-2">{{ m.avatar(user, 'sm') }}{{ user.displayName }}</span></td>
                            <td class="small text-muted">{{ user.email }}</td>
                            <td class="small">
                                {% for pool in user.pools %}<span class="badge text-bg-light text-dark border">{{ pool.name }}</span> {% else %}<span class="text-muted">&mdash;</span>{% endfor %}
                            </td>
                            <td>{% if user.admin %}<span class="badge text-bg-primary">{{ 'admin.is_admin'|trans }}</span>{% endif %}</td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('admin_participant_edit', {id: user.id}) }}">{{ 'common.edit'|trans }}</a>
                                {% if app.user.id != user.id %}
                                    {{ m.csrf_button(path('admin_participant_delete', {id: user.id}), csrf_token('delete-participant-' ~ user.id), 'common.delete'|trans, 'danger', 'admin.confirm_delete_participant'|trans) }}
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-center text-muted py-3">{{ 'admin.no_participants'|trans }}</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <a class="btn btn-link mt-3" href="{{ path('admin_dashboard') }}">{{ 'admin.back'|trans }}</a>
{% endblock %}
