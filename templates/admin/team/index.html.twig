{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.teams'|trans }} — {{ 'admin.title'|trans }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">{{ 'admin.teams'|trans }}</h1>
        <a class="btn btn-success" href="{{ path('admin_team_new') }}">{{ 'admin.new_team'|trans }}</a>
    </div>

    <div class="card shadow-sm">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>{{ 'admin.name'|trans }}</th><th>{{ 'admin.code'|trans }}</th><th class="text-end">{{ 'admin.actions'|trans }}</th></tr></thead>
            <tbody>
                {% for team in teams %}
                    <tr>
                        <td>{{ team.name }}</td>
                        <td>{{ team.code ?? '—' }}</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('admin_team_edit', {id: team.id}) }}">{{ 'common.edit'|trans }}</a>
                            <form method="post" action="{{ path('admin_team_delete', {id: team.id}) }}" class="d-inline"
                                  onsubmit="return confirm('{{ 'admin.confirm_delete_team'|trans }}');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-team-' ~ team.id) }}">
                                <button class="btn btn-sm btn-outline-danger">{{ 'common.delete'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="3" class="text-center text-muted py-3">{{ 'admin.no_teams'|trans }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <a class="btn btn-link mt-3" href="{{ path('admin_dashboard') }}">{{ 'admin.back'|trans }}</a>
{% endblock %}
