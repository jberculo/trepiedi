{% extends 'base.html.twig' %}

{% import '_macros.html.twig' as m %}

{% block title %}{{ pool.name }} — {{ 'admin.members'|trans }}{% endblock %}

{% block body %}
    <h1 class="h3 mb-1">{{ pool.name }}</h1>
    <p class="text-muted mb-3">{{ 'admin.pool_code'|trans }}: <code>{{ pool.code }}</code></p>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'lb.player'|trans }}</th>
                        <th>{{ 'auth.email'|trans }}</th>
                        <th class="text-end">{{ 'admin.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for member in pool.members %}
                        <tr>
                            <td>{{ member.displayName }}</td>
                            <td class="small text-muted">{{ member.email }}</td>
                            <td class="text-end">
                                {{ m.csrf_button(path('admin_pool_member_remove', {id: pool.id, userId: member.id}), csrf_token('remove-member-' ~ pool.id ~ '-' ~ member.id), 'admin.remove_member'|trans, 'danger', 'admin.confirm_remove_member'|trans) }}
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="text-center text-muted py-3">{{ 'admin.no_members'|trans }}</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <a class="btn btn-link mt-3" href="{{ path('admin_pool_index') }}">{{ 'admin.back_to_pools'|trans }}</a>
{% endblock %}
