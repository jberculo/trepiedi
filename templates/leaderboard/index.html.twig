{% extends 'base.html.twig' %}

{% import 'leaderboard/_lb.html.twig' as lb %}

{% block title %}{{ 'lb.title'|trans }} - Trepiedi{% endblock %}

{% block body %}
    {% set maxNow = activeTab in ['points', 'animation'] ? lb.pts(maxPossible) : (activeRanking.max_now_kind == 'triple-finished' ? totalFinished * 3 : totalFinished) %}
    {% set maxTour = activeTab in ['points', 'animation'] ? lb.pts(maxTournament) : (activeRanking.max_tour_kind == 'triple-total' ? totalMatches * 3 : totalMatches) %}
    <div class="lb-hero mb-3">
        <h1 class="h3 mb-0">&#9917; {{ 'lb.title'|trans }}{% if activePool and not activePool.default %} - {{ activePool.name }}{% endif %}</h1>
        {% if activeTab != 'animation' %}
            <span class="lb-hero-max small">{{ 'lb.max'|trans({'%now%': maxNow, '%all%': maxTour}) }}</span>
        {% endif %}
    </div>

    {% set tabs = [
        {tab: 'points',       url: path('app_leaderboard'),              label: 'lb.tab_general'},
        {tab: 'score',        url: path('app_leaderboard_score'),        label: 'lb.tab_balls'},
        {tab: 'winners',      url: path('app_leaderboard_winners'),      label: 'lb.tab_oracle'},
        {tab: 'lantern',      url: path('app_leaderboard_lantern'),      label: 'lb.tab_lantern'},
        {tab: 'inconsistent', url: path('app_leaderboard_inconsistent'), label: 'lb.tab_inconsistent'},
        {tab: 'animation',    url: path('app_leaderboard_animation'),    label: 'lb.tab_animation'},
    ] %}

    <div class="d-md-none mb-3">
        <select class="form-select" aria-label="{{ 'lb.choose_ranking'|trans }}" onchange="if (this.value) window.location.href = this.value;">
            {% for t in tabs %}
                <option value="{{ t.url }}" {{ activeTab == t.tab ? 'selected' }}>{{ t.label|trans }}</option>
            {% endfor %}
        </select>
    </div>

    <ul class="nav nav-tabs mb-3 d-none d-md-flex">
        {% for t in tabs %}
            <li class="nav-item">
                <a class="nav-link {{ activeTab == t.tab ? 'active' }}" href="{{ t.url }}">{{ t.label|trans }}</a>
            </li>
        {% endfor %}
    </ul>

    {% if activeTab not in ['animation', 'lantern', 'inconsistent'] %}
        <p class="text-muted small">
            <span class="rise">&#9650;</span>/<span class="text-danger">&#9660;</span> = {{ 'lb.movement_legend'|trans }}
        </p>
    {% endif %}

    {% if activeTab != 'animation' %}
        {% include 'leaderboard/_ranking_table.html.twig' with {
            entries: activeRanking.entries,
            intro: activeRanking.intro,
            showArrow: activeRanking.showArrow,
            arrowKey: activeRanking.arrowKey,
            rankField: activeRanking.rankField,
            mode: activeRanking.mode,
            rounds: rounds,
            finishedPerRound: finishedPerRound,
            maxPossible: maxPossible,
            totalFinished: totalFinished
        } only %}
    {% endif %}

    {% if activeTab == 'animation' %}
        <p class="text-muted small">{{ 'lb.anim_intro'|trans }}</p>
        {% set metrics = [
            {key: 'points',       label: 'lb.anim_general'},
            {key: 'score',        label: 'lb.tab_balls'},
            {key: 'winners',      label: 'lb.tab_oracle'},
            {key: 'lantern',      label: 'lb.anim_lantern'},
            {key: 'inconsistent', label: 'lb.tab_inconsistent'},
        ] %}

        <div class="d-md-none mb-3">
            <select class="form-select" id="anim-metric-select" aria-label="{{ 'lb.choose_ranking'|trans }}">
                {% for mtr in metrics %}
                    <option value="{{ mtr.key }}">{{ mtr.label|trans }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="btn-group btn-group-sm mb-3 d-none d-md-inline-flex" role="group" aria-label="{{ 'lb.choose_ranking'|trans }}">
            {% for mtr in metrics %}
                <button type="button" class="btn btn-outline-success {{ loop.first ? 'active' }}" data-metric="{{ mtr.key }}">{{ mtr.label|trans }}</button>
            {% endfor %}
        </div>
        <div class="mb-3">
            <button id="anim-play" class="btn btn-success btn-sm" type="button">{{ 'lb.play'|trans }}</button>
            <button id="anim-restart" class="btn btn-outline-secondary btn-sm" type="button">{{ 'lb.restart'|trans }}</button>
            <span id="anim-status" class="ms-2 text-muted small"></span>
        </div>
        <div class="card shadow-sm"><div class="card-body">
            <div id="anim-board" class="anim-board"
                 data-avatar-base="{{ asset('uploads/avatars/') }}"
                 data-t-match="{{ 'lb.anim_match'|trans }}"
                 data-t-done="{{ 'lb.anim_done'|trans }}"
                 data-t-ready="{{ 'lb.anim_ready'|trans }}"
                 data-t-none="{{ 'lb.anim_none'|trans }}"
                 data-t-play="{{ 'lb.play'|trans }}"
                 data-t-pause="{{ 'lb.pause'|trans }}"></div>
        </div></div>
        <script type="application/json" id="anim-data">{{ timeline|json_encode|raw }}</script>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {% if activeTab == 'animation' %}
        <script src="{{ asset('js/leaderboard-animation.js') }}?v={{ asset_version('js/leaderboard-animation.js') }}"></script>
    {% endif %}
{% endblock %}
