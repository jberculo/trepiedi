{# Klassement-specifieke opmaakmacro's, gedeeld door de index en de ranking-tabel. #}

{# Getal netjes: heel getal zonder decimalen, anders een decimaal (NL-notatie). #}
{% macro pts(v) %}{{ v == v|round ? v|number_format(0, ',', '.') : v|number_format(1, ',', '.') }}{% endmacro %}

{# Positieverandering t.o.v. de vorige stand: omhoog, omlaag, of gelijk. De pijl
   wijst de werkelijke positieverandering aan; met invert=true (straf-klassementen)
   zijn de kleuren omgedraaid: stijgen = rood (slechter), dalen = groen (beter). #}
{% macro arrow(change, invert = false) %}{% if change is not null %}{% if change > 0 %}<span class="small {{ invert ? 'text-danger' : 'rise' }}" title="{{ 'lb.rose'|trans }}">▲{{ change }}</span>{% elseif change < 0 %}<span class="small {{ invert ? 'rise' : 'text-danger' }}" title="{{ 'lb.fell'|trans }}">▼{{ -change }}</span>{% else %}<span class="text-muted small" title="{{ 'lb.equal'|trans }}">=</span>{% endif %}{% endif %}{% endmacro %}

{# Legenda-pijlen met dezelfde invert-kleurlogica als arrow(): omhoog / omlaag. #}
{% macro legend(invert = false) %}<span class="{{ invert ? 'text-danger' : 'rise' }}">▲</span>/<span class="{{ invert ? 'rise' : 'text-danger' }}">▼</span>{% endmacro %}

{# Score-onderdelen van een ronde: thuis / uit / exact / winnaar. #}
{% macro stat(home, away, exact, winner) %}{{ home }}&times; {{ 'lb.home'|trans }} &middot; {{ away }}&times; {{ 'lb.away'|trans }} &middot; {{ exact }}&times; {{ 'lb.exact'|trans }} &middot; {{ winner }}&times; {{ 'lb.winner'|trans }}{% endmacro %}

{# Totaal t.o.v. het maximum, met het percentage eronder. #}
{% macro total(value, max) %}{{ _self.pts(value) }}/{{ _self.pts(max) }}<br><small class="text-muted fw-normal">{{ max > 0 ? (value / max * 100)|round : 0 }}%</small>{% endmacro %}

{# Medaillekleur voor de top 3. #}
{% macro medal(rank) %}{% if rank == 1 %}medal-gold{% elseif rank == 2 %}medal-silver{% elseif rank == 3 %}medal-bronze{% endif %}{% endmacro %}
